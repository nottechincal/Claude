# ============================================================
# Cranny Boys Pizza AI Hub - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (Voice, SMS, WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+61xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Database
DATABASE_URL=postgresql+asyncpg://crannyboyspizza:crannyboyspizza@localhost:5432/crannyboyspizza

# Redis (using DB 1 to avoid conflict with kebabalab on DB 0)
REDIS_URL=redis://localhost:6379/1

# Public URL (for Twilio webhooks)
# Use ngrok for dev: https://xxxx.ngrok.io
BASE_URL=https://your-domain.com

# Shop timezone
SHOP_TIMEZONE=Australia/Melbourne

# Session TTL (seconds)
SESSION_TTL=1800

# ngrok (for local dev)
NGROK_AUTHTOKEN=

# Dashboard auth (optional, for production)
DASHBOARD_SECRET=change-me-in-production

# Log level
LOG_LEVEL=INFO
